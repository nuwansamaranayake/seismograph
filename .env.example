# ---- LLM via OpenRouter (required) ----
OPENROUTER_API_KEY=sk-or-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Pick model IDs by task from https://openrouter.ai/models
LLM_MODEL_REASONING=REPLACE_WITH_OPENROUTER_MODEL_ID
LLM_MODEL_EXTRACTION=REPLACE_WITH_OPENROUTER_MODEL_ID
LLM_MODEL_JUDGE=REPLACE_WITH_OPENROUTER_MODEL_ID
EMBEDDING_MODEL=REPLACE_WITH_OPENROUTER_MODEL_ID
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# ---- Runtime ----
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
SMOKE_TEST_TOKEN=dev-smoke-token

# ---- Data (required) ----
DATABASE_URL=postgresql+psycopg://aignite:aignite@localhost:5432/seismograph
REDIS_URL=redis://localhost:6379/0
EXPECTED_TABLE_COUNT=9

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=seismograph

# Self-hosted cross-encoder for metamorphic variant back-check
NLI_MODEL=cross-encoder/nli-deberta-v3-base
ANCHOR_SET_PATH=./data/synthetic/anchor_set.jsonl
# Systems under test are configured per-contract in YAML, not here.
